				(size 1.27 1.27)
			)
			(justify left)
			(href "https://www.ti.com/lit/ds/symlink/ina826.pdf?ts=1764692542907#page=18")
		)
		(uuid "e1c3d6de-9d08-4566-8612-f3f220f69d23")
	)
